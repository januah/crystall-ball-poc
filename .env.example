# Supabase — get these from your project's API settings
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server-side only, never expose to client
SUPABASE_SERVICE_ROLE_KEY=

# JWT signing secret — minimum 32 characters, generate with: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRES_IN=8h

# OpenRouter (AI pipeline)
OPENROUTER_API_KEY=

# Cron security — random string, set the same in Vercel Cron config
CRON_SECRET=

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=

# App URL (used for share links and WhatsApp alerts)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
